{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Menaia Docs",
  "colors": {
    "primary": "#7C5CFF",
    "light": "#BAA7FF",
    "dark": "#6A4DE0"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Estimates",
        "icon": "calculator",
        "pages": [
          "estimates/create"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
